# === Obrigatório para o app subir ===
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

NEXT_PUBLIC_APP_URL=https://seu-dominio.vercel.app

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding

# IA (texto) — pipeline, chat do card, assistentes
ANTHROPIC_API_KEY=sk-ant-...

# === Stripe (checkout, portal, webhook) ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# === Redes / OAuth (só o que você for usar) ===
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Opcional: segundo app LinkedIn só com Community Management API (páginas de empresa)
LINKEDIN_PAGES_CLIENT_ID=
LINKEDIN_PAGES_CLIENT_SECRET=

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# === Mídia / pipeline (imagem, infográfico, Veo) ===
GEMINI_API_KEY=

# Conta de serviço GCP (JSON inteiro em UMA linha, sem aspas externas)
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1
# Bucket público para URLs https://storage.googleapis.com/... (vídeo Veo)
GOOGLE_CLOUD_STORAGE_BUCKET=

# === Cron (Vercel Cron chama /api/cron/pipeline com Bearer) ===
CRON_SECRET=
